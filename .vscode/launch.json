{
	"configurations": [
		{
			"name": "Run Application",
			"command": "npm run dev",
			"request": "launch",
			"type": "node-terminal",
			"serverReadyAction": {
				"pattern": "\\b(https?://localhost:\\d+)",
				"action": "openExternally"
			}
		},
		{
			"name": "Install Dependencies",
			"command": "npm install",
			"request": "launch",
			"type": "node-terminal"
		},
		{
			"name": "Lint Code",
			"command": "npm run lint",
			"request": "launch",
			"type": "node-terminal"
		}
	]
}
